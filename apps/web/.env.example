# Rootine OS — frontend env (Vite exposes only VITE_* to the client).
# NEVER put the Supabase service-role key here or anywhere in the frontend.
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Optional — auto cover photos for workout templates that don't have a manual
# image set (Sport > Dzisiaj). Get a free key at https://www.pexels.com/api/.
# The app works fine without it: it just falls back to the gradient placeholder.
VITE_PEXELS_API_KEY=your-pexels-api-key
